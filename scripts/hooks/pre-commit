#!/usr/bin/env bash
# git pre-commit hook. runs Biome, rustfmt, and clippy checks before every commit
set -euo pipefail

# skip in CI. github actions already runs biome check independently
if [ -n "${CI:-}" ]; then
  exit 0
fi

exit_code=0

# Biome (TS/JS/JSON)
biome_staged=$(git diff --cached --name-only --diff-filter=ACMR | grep -E '\.(tsx?|jsx?|json[c]?)$' || true)

if [ -n "$biome_staged" ]; then
  echo "🔍 Running Biome check…"

  # --write:  auto-fix safe issues (formatting + safe lints)
  # --staged: only check staged files; also re-stages any files Biome modifies
  if pnpm exec biome check --write --staged .; then
    echo "✅ Biome check passed."
  else
    echo ""
    echo "❌ Biome found errors that couldn't be auto-fixed."
    echo "   Run 'pnpm run fix', review the output, re-stage and try again."
    exit_code=1
  fi
fi

# rustfmt + clippy (Rust)
rust_staged=$(git diff --cached --name-only --diff-filter=ACMR | grep -E '\.rs$' || true)

if [ -n "$rust_staged" ]; then
  echo "🔍 Running rustfmt check…"

  # --check: exit non-zero if any files would be reformatted (matches CI exactly)
  if cargo fmt --manifest-path src-tauri/Cargo.toml -- --check; then
    echo "✅ rustfmt check passed."
  else
    echo ""
    echo "❌ Rust formatting issues found."
    echo "   Run 'cargo fmt --manifest-path src-tauri/Cargo.toml' to fix, then re-stage."
    exit_code=1
  fi

  echo "🔍 Running clippy…"

  # matches CI exactly: --all-targets -D warnings
  if cargo clippy --manifest-path src-tauri/Cargo.toml --all-targets -- -D warnings; then
    echo "✅ Clippy passed."
  else
    echo ""
    echo "❌ Clippy found issues."
    echo "   Fix the errors above, then re-stage and try again."
    exit_code=1
  fi
fi

exit $exit_code
