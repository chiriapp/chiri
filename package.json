{
  "name": "chiri",
  "version": "0.9.2",
  "author": "Sapphic Angels",
  "description": "Cross-platform CalDAV task management app.",
  "type": "module",
  "packageManager": "pnpm@11.1.2",
  "license": "zlib/libpng",
  "scripts": {
    "build": "tsc && vite build",
    "check": "biome check",
    "dev": "vite",
    "format": "biome format --write .",
    "fix": "biome check --write .",
    "lint": "biome lint .",
    "lint:rust": "cargo clippy --manifest-path src-tauri/Cargo.toml --all-targets -- -D warnings",
    "test": "vitest run --project=node --project=jsdom",
    "test:coverage": "vitest run --project=node --project=jsdom --coverage",
    "test:integration": "vitest run --project=integration",
    "test:integration:all": "bash scripts/test-integration-all.sh",
    "test:watch": "vitest --project=node --project=jsdom"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@tanstack/react-query": "^5.101.1",
    "@tauri-apps/api": "^2.11.1",
    "@tauri-apps/plugin-autostart": "^2.5.1",
    "@tauri-apps/plugin-deep-link": "^2.4.9",
    "@tauri-apps/plugin-dialog": "2.7.1",
    "@tauri-apps/plugin-fs": "2.5.1",
    "@tauri-apps/plugin-http": "^2.5.9",
    "@tauri-apps/plugin-log": "^2.8.0",
    "@tauri-apps/plugin-notification": "^2.3.3",
    "@tauri-apps/plugin-opener": "~2.5.4",
    "@tauri-apps/plugin-os": "~2.3.2",
    "@tauri-apps/plugin-process": "~2.3.1",
    "@tauri-apps/plugin-sql": "2.4.0",
    "@tauri-apps/plugin-updater": "^2.10.1",
    "date-fns": "^4.4.0",
    "frimousse": "^0.3.0",
    "lucide-react": "^1.21.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "rrule-temporal": "^1.5.3",
    "sonner": "^2.0.7"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.0",
    "@tailwindcss/vite": "^4.3.1",
    "@tauri-apps/cli": "^2.11.3",
    "@types/node": "^25.9.4",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.9",
    "@xmldom/xmldom": "^0.9.10",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.0.8",
    "tailwindcss": "^4.3.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.9",
    "vitest-canvas-mock": "^1.1.4"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,json,jsonc}": "biome check --write",
    "*.rs": "cargo fmt --manifest-path src-tauri/Cargo.toml --"
  }
}
