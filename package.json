{
  "name": "chiri",
  "version": "0.9.0",
  "author": "Sapphic Angels",
  "description": "A cross-platform CalDAV task management app. Currently in very early alpha!",
  "type": "module",
  "license": "zlib/libpng",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "check": "biome check --write .",
    "test": "vitest run --project=node --project=jsdom",
    "test:watch": "vitest --project=node --project=jsdom",
    "test:coverage": "vitest run --project=node --project=jsdom --coverage",
    "test:integration": "node --env-file=.env.local ./node_modules/vitest/vitest.mjs run --project=integration",
    "test:integration:all": "bash scripts/test-integration-all.sh"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@tanstack/react-query": "^5.100.11",
    "@tauri-apps/api": "^2.11.0",
    "@tauri-apps/plugin-autostart": "^2.5.1",
    "@tauri-apps/plugin-deep-link": "^2.4.9",
    "@tauri-apps/plugin-log": "^2.8.0",
    "@tauri-apps/plugin-notification": "^2.3.3",
    "@tauri-apps/plugin-opener": "~2.5.4",
    "@tauri-apps/plugin-os": "~2.3.2",
    "@tauri-apps/plugin-process": "~2.3.1",
    "@tauri-apps/plugin-sql": "2.4.0",
    "@tauri-apps/plugin-updater": "^2.10.1",
    "date-fns": "^4.2.1",
    "frimousse": "^0.3.0",
    "lucide-react": "^1.16.0",
    "marked": "^18.0.4",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "rrule-temporal": "^1.5.3",
    "sonner": "^2.0.7"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.15",
    "@tailwindcss/vite": "^4.3.0",
    "@tauri-apps/cli": "^2.11.2",
    "@tauri-apps/plugin-dialog": "2.7.1",
    "@tauri-apps/plugin-fs": "2.5.1",
    "@tauri-apps/plugin-http": "^2.5.9",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/coverage-v8": "^4.1.7",
    "@xmldom/xmldom": "^0.9.10",
    "jsdom": "^29.1.1",
