# integration tests against a real CalDAV server. set these locally in .env.local
# (gitignored) to run `pnpm test:integration`. the disposable test account should
# be on a server you control
CHIRI_TEST_CALDAV_URL=
CHIRI_TEST_CALDAV_USERNAME=
CHIRI_TEST_CALDAV_PASSWORD=

# server type for the integration suite. one of: rustical, nextcloud, baikal,
# radicale, fruux, vikunja, generic. defaults to 'generic' (auto-discovery)
CHIRI_TEST_CALDAV_TYPE=generic
