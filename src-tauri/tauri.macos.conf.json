{
  "build": {
    "beforeBundleCommand": "cd src-tauri && ./fix-libs.sh"
  },
  "app": {
    "windows": [
      {
        "fullscreen": false,
        "resizable": true,
        "title": "Chiri",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "dragDropEnabled": false,
        "backgroundColor": "#18181B",
        "visible": false,
        "focus": true
      }
    ]
  },
  "bundle": {
    "targets": ["dmg"],
    "icon": ["gen/Chiri.icns"],
    "resources": {
      "gen/Assets.car": "Assets.car",
      "gen/Chiri.icns": "Chiri.icns",
      "gen/partial.plist": "partial.plist"
    },
    "macOS": {
      "infoPlist": "Info.plist",
      "dmg": {
        "appPosition": {
          "x": 100,
          "y": 103
        },
        "applicationFolderPosition": {
          "x": 373,
          "y": 103
        },
        "background": "./Chiri.dmg.png",
        "windowPosition": {
          "x": 600,
          "y": 400
        },
        "windowSize": {
          "width": 512,
          "height": 340
        }
      }
    }
  }
}
