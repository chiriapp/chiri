{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Chiri",
  "version": "0.9.0",
  "identifier": "moe.sapphic.Chiri",
  "build": {
    "beforeDevCommand": "pnpm run dev",
    "beforeBuildCommand": "pnpm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist",
    "removeUnusedCommands": true
  },
  "app": {
    "windows": [
      {
        "fullscreen": false,
        "resizable": true,
        "title": "Chiri",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "dragDropEnabled": false,
        "backgroundColor": "#18181B",
        "visible": false,
        "focus": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "category": "Productivity",
    "publisher": "Chiri",
    "homepage": "https://github.com/chiriapp/chiri",
    "copyright": "Copyright (c) 2026 Sapphic Angels"
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["garden.chiri"]
      }
    },
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDIzOTVCODlGODdBNkM5QTkKUldTcHlhYUhuN2lWSTNRT2UzWlJ0OE5EV1pCNkJyM0o1L2lvRmZPSkxCeDZJRExPMGg2eE85ZzQK",
      "endpoints": ["https://github.com/SapphoSys/chiri/releases/latest/download/latest.json"]
    }
  }
}
