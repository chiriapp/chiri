{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capability for Chiri",
  "windows": ["main"],
  "permissions": [
    "core:default",
    {
      "identifier": "http:default",
      "allow": [
        {
          "url": "http://*:*"
        },
        {
          "url": "https://*:*"
        }
      ]
    },
    "core:window:allow-show",
    "dialog:default",
    "fs:default",
    {
      "identifier": "fs:allow-remove",
      "allow": [
        {
          "path": "$APPLOCALDATA/chiri.db"
        },
        {
          "path": "$APPCONFIG/chiri.db"
        }
      ]
    },
    "notification:default",
    "sql:default",
    "sql:allow-execute",
    "process:default",
    "core:window:allow-set-focus",
    "os:default",
    "log:default",
    {
      "identifier": "opener:default",
      "allow": [
        {
          "url": "http://*"
        },
        {
          "url": "https://*"
        },
        {
          "url": "x-apple.systempreferences:*"
        }
      ]
    },
    "updater:default"
  ]
}
