{
  "mainBinaryName": "Chiri",
  "app": {
    "enableGTKAppId": true,
    "windows": [
      {
        "fullscreen": false,
        "resizable": true,
        "title": "Chiri",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "dragDropEnabled": true,
        "backgroundColor": "#18181B",
        "visible": false
      }
    ]
  },
  "bundle": {
    "targets": ["deb", "rpm", "appimage"],
    "icon": ["icons/32x32.png", "icons/128x128.png", "icons/128x128@2x.png", "icons/icon.png"],
    "linux": {
      "deb": {
        "desktopTemplate": "garden.chiri.Chiri.desktop"
      },
      "rpm": {
        "desktopTemplate": "garden.chiri.Chiri.desktop"
      }
    }
  }
}
