{
  "app": {
    "enableGTKAppId": true,
    "windows": [
      {
        "dragDropEnabled": true
      }
    ]
  },
  "bundle": {
    "targets": ["deb", "rpm"],
    "icon": ["icons/32x32.png", "icons/128x128.png", "icons/128x128@2x.png", "icons/icon.png"],
    "linux": {
      "deb": {
        "desktopTemplate": "Chiri.desktop"
      },
      "rpm": {
        "desktopTemplate": "Chiri.desktop"
      }
    }
  }
}
